{% if pagination and pagination.pages is iterable %}
<nav role="navigation" aria-label="pagination"
     class="flex items-center justify-between gap-4 font-light uppercase">

    {# Previous #}
    {% if pagination.prev %}
        <a href="{{ pagination.prev.link }}"
           class="{{ pagination.prev.class }} flex items-center gap-2 text-primary-light hocus:underline min-w-[44px] min-h-[44px]">
            <span role="presentation">&lt;&lt;</span>
            <span class="hidden sm:inline">Previous</span>
        </a>
    {% else %}
        <span class="min-w-[44px]"></span>
    {% endif %}

    {# Page numbers #}
    <ul class="hidden md:flex items-center gap-2 pages">
        {% for page in pagination.pages %}
            <li>
                {% if page.current %}
                    <span class="font-bold flex items-center justify-center min-w-[44px] min-h-[44px]">
                        {{ page.title }}
                    </span>
                {% else %}
                    <a href="{{ page.link }}"
                       class="flex items-center justify-center text-primary-light hocus:underline min-w-[44px] min-h-[44px]">
                        {{ page.title }}
                    </a>
                {% endif %}
            </li>

            {% if page.beforeBreak %}
                <li role="presentation" class="px-1">…</li>
            {% endif %}
        {% endfor %}
    </ul>

    {# Next #}
    {% if pagination.next %}
        <a href="{{ pagination.next.link }}"
           class="{{ pagination.next.class }} flex items-center gap-2 text-primary-light hocus:underline min-w-[44px] min-h-[44px]">
            <span class="hidden sm:inline">Next</span>
            <span role="presentation">&gt;&gt;</span>
        </a>
    {% else %}
        <span class="min-w-[44px]"></span>
    {% endif %}

</nav>
{% endif %}